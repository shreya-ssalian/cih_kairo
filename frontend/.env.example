# Where the SeaPulse FastAPI backend is running. If it's unreachable, the
# app automatically falls back to its original in-browser simulation, so
# this is optional for a quick demo but required to use the real backend.
VITE_API_URL=http://localhost:8000

# Optional override; by default this is derived from VITE_API_URL
# (http -> ws, plus /ws/stream).
# VITE_WS_URL=ws://localhost:8000/ws/stream
